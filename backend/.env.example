# ImmersiveRAG Backend — Environment Variables Template
# ───────────────────────────────────────────────────────
# Copy this file to .env and fill in your credentials.
# .env is gitignored and should NEVER be committed.
#
#   cp .env.example .env   (macOS/Linux)
#   copy .env.example .env  (Windows)

# ── Embedding API (OpenAI-compatible) ──────────────────────────────────────
# If NOT set → system uses local FastEmbed (384-dim, zero cost). Safe for dev.
IMMERSIVE_RAG_OPENAI_API_KEY=
IMMERSIVE_RAG_OPENAI_BASE_URL=https://your-company-api-gateway.example.com/v1
IMMERSIVE_RAG_EMBEDDING_MODEL=text-embedding-3-small

# ── LLM Generation API — Agent Reasoning & Chat ────────────────────────────
# Supports any OpenAI-compatible endpoint:
#   Groq:   https://api.groq.com/openai/v1  |  models: llama-3.3-70b-versatile, mixtral-8x7b-32768
#   Azure:  https://<resource>.openai.azure.com/openai/deployments/<model>  
#   OpenAI: https://api.openai.com/v1       |  models: gpt-4o, gpt-4o-mini
IMMERSIVE_RAG_LLM_API_KEY=
IMMERSIVE_RAG_LLM_BASE_URL=https://api.groq.com/openai/v1
IMMERSIVE_RAG_LLM_MODEL=llama-3.3-70b-versatile

# ── LlamaParse Cloud (Optional — high-fidelity PDF extraction) ─────────────
# Free tier: https://cloud.llamaindex.ai
IMMERSIVE_RAG_LLAMA_PARSE_API_KEY=

