# ImmersiveRAG Backend — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your company credentials.
# .env is gitignored and should NEVER be committed.
#
# Usage:
#   cp .env.example .env
#   Fill in the values below

# ── Company Embedding API (OpenAI-compatible endpoint) ────────────────────
# Required for the "OpenAI (Corporate API)" mode in the UI.
# If unset, the system will automatically fall back to local FastEmbed.
IMMERSIVE_RAG_OPENAI_API_KEY=
IMMERSIVE_RAG_OPENAI_BASE_URL=https://your-company-api-gateway.example.com/v1
IMMERSIVE_RAG_EMBEDDING_MODEL=text-embedding-3-small

# ── Company LLM Reasoning API (Generation / Chat Model) ───────────────────
# For extending the agent to produce generated answers, not just chunks.
# (Not used in the base retrieval-only mode — for future agent extensions)
IMMERSIVE_RAG_LLM_API_KEY=
IMMERSIVE_RAG_LLM_BASE_URL=https://your-company-api-gateway.example.com/v1
IMMERSIVE_RAG_LLM_MODEL=gpt-4o

# ── LlamaParse Cloud (Optional) ────────────────────────────────────────────
# High-fidelity PDF-to-Markdown extraction via LlamaIndex cloud.
# Only needed if using "LlamaParse (Cloud)" extraction mode in the UI.
# Free tier available at: https://cloud.llamaindex.ai
IMMERSIVE_RAG_LLAMA_PARSE_API_KEY=
